{
  "name": "hbs-master",
  "displayName": "HBS Master",
  "description": "VS Code tooling for Handlebars partial navigation, autocomplete, diagnostics, and HBSDoc documentation.",
  "icon": "assets/logo.png",
  "version": "1.0.0",
  "publisher": "poliklot",
  "author": {
    "name": "poliklot"
  },
  "license": "MIT",
  "homepage": "https://github.com/poliklot/hbs-master",
  "repository": {
    "type": "git",
    "url": "https://github.com/poliklot/hbs-master.git"
  },
  "bugs": {
    "url": "https://github.com/poliklot/hbs-master/issues"
  },
  "keywords": [
    "handlebars",
    "hbs",
    "partials",
    "templates",
    "navigation",
    "autocomplete"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:handlebars"
  ],
  "scripts": {
    "compile": "tsc",
    "vscode:prepublish": "npm run compile",
    "prepackage": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "npm run compile && npm run test:unit",
    "test:unit": "node --test test/*.test.cjs",
    "test:integration": "npm run compile && node test/integration/run.cjs",
    "test:all": "npm test && npm run test:integration"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "HBS Master",
      "properties": {
        "hbsMaster.partialsPath": {
          "type": "string",
          "default": "src/partials",
          "description": "Путь к папке с партиалами относительно корня проекта"
        },
        "hbsMaster.enableHoverDocs": {
          "type": "boolean",
          "default": true,
          "description": "Включить показ документации при наведении"
        },
        "hbsMaster.enableSignatureHelp": {
          "type": "boolean",
          "default": true,
          "description": "Включить подсказки параметров"
        },
        "hbsMaster.enableParameterHighlight": {
          "type": "boolean",
          "default": true,
          "description": "Включить подсветку параметров"
        },
        "hbsMaster.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Включить диагностики partials и параметров компонентов"
        },
        "hbsMaster.diagnosticsSeverity": {
          "type": "string",
          "enum": ["hint", "information", "warning", "error"],
          "default": "warning",
          "description": "Уровень важности диагностик HBS Master"
        }
      }
    },
    "languages": [
      {
        "id": "handlebars",
        "extensions": [
          ".hbs"
        ]
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.101.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@poliklot/prettier-plugin-handlebars": "^0.2.12"
  }
}
