{
  "name": "hbs-master",
  "displayName": "HBS Master",
  "description": "VS Code tooling for Handlebars partial navigation, autocomplete, diagnostics, and HBSDoc documentation.",
  "icon": "assets/logo.png",
  "version": "1.0.0",
  "publisher": "poliklot",
  "author": {
    "name": "poliklot"
  },
  "license": "MIT",
  "homepage": "https://github.com/poliklot/hbs-master",
  "repository": {
    "type": "git",
    "url": "https://github.com/poliklot/hbs-master.git"
  },
  "bugs": {
    "url": "https://github.com/poliklot/hbs-master/issues"
  },
  "keywords": [
    "handlebars",
    "hbs",
    "partials",
    "templates",
    "navigation",
    "autocomplete"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Navigation and documentation remain available, while file-creation Quick Fixes are disabled.",
      "restrictedConfigurations": [
        "hbsMaster.partialsPath",
        "hbsMaster.partialsPaths"
      ]
    },
    "virtualWorkspaces": {
      "supported": false
    }
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:handlebars"
  ],
  "scripts": {
    "compile": "tsc",
    "vscode:prepublish": "npm run compile",
    "prepackage": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "npm run compile && npm run test:unit",
    "test:unit": "node --test test/*.test.cjs",
    "test:integration": "npm run compile && node test/integration/run.cjs",
    "test:all": "npm test && npm run test:integration"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "HBS Master",
      "properties": {
        "hbsMaster.partialsPath": {
          "type": "string",
          "default": "src/partials",
          "scope": "resource",
          "description": "Path to the partials directory, relative to the current workspace folder. Used when partialsPaths is empty."
        },
        "hbsMaster.partialsPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Ordered partials directories relative to the current workspace folder. The first directory is used when creating a missing partial."
        },
        "hbsMaster.enableHoverDocs": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Show HBSDoc documentation on hover."
        },
        "hbsMaster.enableSignatureHelp": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Show component parameter signature help."
        },
        "hbsMaster.enableParameterHighlight": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Highlight matching parameters in partial calls."
        },
        "hbsMaster.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Report partial and documented component parameter problems."
        },
        "hbsMaster.diagnosticsSeverity": {
          "type": "string",
          "enum": [
            "hint",
            "information",
            "warning",
            "error"
          ],
          "default": "warning",
          "scope": "resource",
          "description": "Severity used for HBS Master diagnostics."
        }
      }
    },
    "languages": [
      {
        "id": "handlebars",
        "extensions": [
          ".hbs",
          ".handlebars"
        ]
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.101.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@poliklot/prettier-plugin-handlebars": "^0.2.12"
  }
}
